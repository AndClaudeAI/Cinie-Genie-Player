{
  "name": "Cinie Genie Player",
  "short_name": "Cinie Genie",
  "description": "Streaming video player with IPTV support, up to 8K playback, subtitles, and Dolby Atmos",
  "start_url": "/Cinie-Genie-Player/",
  "scope": "/Cinie-Genie-Player/",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#06060e",
  "background_color": "#06060e",
  "categories": ["entertainment", "utilities"],
  "icons": [
    {
      "src": "icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "icon-maskable.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "screenshots": [],
  "file_handlers": [
    {
      "action": "/Cinie-Genie-Player/",
      "accept": {
        "video/*": [".mp4", ".webm", ".mkv", ".avi", ".mov", ".m4v", ".ts", ".ogv"],
        "application/x-mpegURL": [".m3u8"],
        "audio/mpegurl": [".m3u"]
      }
    }
  ],
  "share_target": {
    "action": "/Cinie-Genie-Player/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["video/*", ".mp4", ".webm", ".mkv"]
        }
      ]
    }
  }
}
